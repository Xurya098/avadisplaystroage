    /* Floating telemetry diagnostic widget positions */
    .ava-telemetry-panel {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
    }

    .ava-telemetry-row {
        display: none !important;
    }

    /* 8. Forms & Contact page inputs responsiveness */

/* ==========================================================================
   AMBIENT BACKGROUNDS & GRID BLUEPRINT SYSTEM
   ========================================================================== */
.ava-ambient-container {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    overflow: hidden !important;

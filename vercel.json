{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/wp-content/themes/hello-elementor/assets/js/premium-ux.js",
      "headers": {
        "cache-control": "no-store, no-cache, must-revalidate, proxy-revalidate"
      },
      "dest": "/wp-content/themes/hello-elementor/assets/js/premium-ux.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
